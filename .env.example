# ==========================================
# 1. 基础系统与网络配置
# ==========================================
PROJECT_NAME="PolyMatrix Engine"
DEBUG=True

# Polymarket 网络设置 (默认: Polygon Mainnet)
PM_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
PM_API_URL=https://clob.polymarket.com
PM_CHAIN_ID=137
ALCHEMY_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your_alchemy_api_key_here

# ==========================================
# 2. 账号与权限凭证 (注意保密)
# ==========================================
PK=your_private_key_here
FUNDER_ADDRESS=your_wallet_address_here

# ==========================================
# 3. 数据库与 Redis 持久化
# ==========================================
# DB_PORT: Docker 映射外部端口(默认 5433，以防和本地 5432 冲突)
DB_PORT=5433
DATABASE_URL=postgresql+asyncpg://postgres:postgres_password@localhost:5433/polymatrix
# REDIS_PORT: Docker 映射外部端口(默认 6380，以防和本地 6379 冲突)
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380/0

# ==========================================
# 4. 交易总控与风险管理
# ==========================================
# 是否允许往交易所发送真实的订单，False 则只在本地模拟落库
LIVE_TRADING_ENABLED=False
# 跨全市场的绝对风控红线 (USDC)
GLOBAL_MAX_BUDGET=280.0
# 单市场最大允许持仓敞口 (USDC)，触碰后引擎将强制平仓该市场
MAX_EXPOSURE_PER_MARKET=40.0
# 账本与 Polymarket API 持仓的差异容忍度 (超过此差异即覆盖本地账本)
EXPOSURE_TOLERANCE=0.01
# 本地刚产生成交后的缓冲秒数，期间内禁止 REST API 强行覆盖本地账本
RECONCILIATION_BUFFER_SECONDS=8.0

# ==========================================
# 5. 网格做市与订单参数
# ==========================================
# 默认的单笔订单金额(USDC)，Polymarket 底线要求是 5 USDC
BASE_ORDER_SIZE=5.0
# 买卖双方各自挂单的网格层数
GRID_LEVELS=2
# 基础点差，决定买卖单距离 Fair Value 的远近
QUOTE_BASE_SPREAD=0.02
# Fair Value 至少移动多少金额才会触发重新挂单
QUOTE_PRICE_OFFSET_THRESHOLD=0.01
# 开启后，如果检测到官方流动性奖励参数(MaxSpread/MinSize)，将自动覆盖上述设置
AUTO_TUNE_FOR_REWARDS=True

# --- 交易细节优化 ---
# 第一档买单最高允许挂在 Best Bid 之下 1 tick，这样更容易接盘成交，且保持利润空间
QUOTE_BID_ONE_TICK_BELOW_TOUCH=true
# 若难以成交，可关掉此项严格挂在 bid_1；或者提高 GRID_LEVELS 多挂几档。

# ==========================================
# 6. V4.0 全自动路由与组合管理器 (Auto-Router)
# ==========================================
AUTO_ROUTER_ENABLED=false
# 系统最多允许同时做市的市场数量 (名额)
AUTO_ROUTER_MAX_MARKETS=8
# 每隔多少秒全网扫描并重组优胜劣汰市场
AUTO_ROUTER_SCAN_INTERVAL_SEC=3600

# ==========================================
# 7. 仪表盘(Dashboard) 与 Gamma API
# ==========================================
# 仪表盘 "Screener" 从 Gamma API 拉取用于分析的最大活跃市场数
# GAMMA_MAX_MARKETS=50000

# 定力锁：市场掉出 Top N 后至少持有多少小时才允许驱逐
AUTO_ROUTER_MIN_HOLD_HOURS=2.0

# V7.0 Auto-Router: skip markets with daily reward pool below this (USD)
AUTO_ROUTER_MIN_REWARD_POOL=50.0

# V7.1 Official Polymarket Builder API credentials (order attribution)
POLY_BUILDER_API_KEY=
POLY_BUILDER_SECRET=
POLY_BUILDER_PASSPHRASE=

# --- V6.2 行业与事件地平线风控 ---
MAX_EXPOSURE_PER_SECTOR=300.0
EVENT_HORIZON_HOURS=72.0
MAX_SLOTS_PER_SECTOR=2

MAX_EXPOSURE_CATEGORICAL=30.0

# ==========================================
# 8. V8.0 保守策略: 单边便宜侧做市 + 即时对冲
# ==========================================
# 只在便宜侧(价格 < 0.45)挂BUY单，贵侧不挂 —— 大幅降低逆向选择风险
SINGLE_SIDE_CHEAP_ONLY=true
# 代币 Fair Value 低于此价格才允许挂BUY单
CHEAP_SIDE_MAX_PRICE=0.45
# BUY成交后立刻挂SELL对冲单，快速平仓
HEDGE_ON_FILL=true
# 对冲单价格 = 成本价 + 此利润空间
HEDGE_MARGIN_CENTS=0.02
# 对冲单超过N个tick未成交后，逐步降价至成本价
HEDGE_DECAY_TICKS=10
# 单市场浮亏超过此金额(USDC)立即退出
PER_MARKET_STOP_LOSS_USD=5.0

# --- V8.0 Auto-Router 市场质量过滤 ---
# 订单簿深度(前3档总名义)低于此值的市场不选
ROUTER_MIN_BOOK_DEPTH_USD=50.0
# 买卖价差超过此值的市场不选
ROUTER_MAX_BOOK_SPREAD=0.08
# 中间价在 0.50 ± 此范围内的市场不选(最大不确定性区间)
ROUTER_AVOID_MIDPOINT_BAND=0.10

PROJECT_NAME="PolyMatrix Engine"
DEBUG=True
LIVE_TRADING_ENABLED=False # Set to True to enable real money order creation/cancellation

# Polymarket Network settings (Default: Polygon Mainnet)
PM_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
PM_API_URL=https://clob.polymarket.com
PM_CHAIN_ID=137

# Trading Credentials (DO NOT COMMIT ACTUAL KEYS)
PK=your_private_key_here
FUNDER_ADDRESS=your_wallet_address_here

# Persistence (Postgres & Redis required)
# DB_PORT: host port for Postgres (default 5433). Use 5433 so 5432 is free for e.g. ThetaMind.
DB_PORT=5433
DATABASE_URL=postgresql+asyncpg://postgres:postgres_password@localhost:5433/polymatrix
# REDIS_PORT: host port for Redis (default 6380). Use 6380 so 6379 is free for e.g. ThetaMind.
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380/0

# Risk Management
MAX_EXPOSURE_PER_MARKET=50.0
ALCHEMY_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your_alchemy_api_key_here

BASE_ORDER_SIZE=5.0
GRID_LEVELS=2
# 少而精：只在有 edge 时成交。第一档可挂在 Best Bid 下 1 tick，更容易被卖单打到（仍保留约 1¢ edge）
QUOTE_BASE_SPREAD=0.02
QUOTE_PRICE_OFFSET_THRESHOLD=0.01
QUOTE_BID_ONE_TICK_BELOW_TOUCH=true

# --- 若仍无成交：选流动性好、有双向波动的市场；或 GRID_LEVELS=3 多挂几档 ---
# QUOTE_BID_ONE_TICK_BELOW_TOUCH=false  # 关掉则严格只挂 bid_1，成交更少、每笔 edge 更大
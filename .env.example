PROJECT_NAME="PolyMatrix Engine"
DEBUG=True
LIVE_TRADING_ENABLED=False # Set to True to enable real money order creation/cancellation

# Polymarket Network settings (Default: Polygon Mainnet)
PM_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
PM_API_URL=https://clob.polymarket.com
PM_CHAIN_ID=137

# Trading Credentials (DO NOT COMMIT ACTUAL KEYS)
PK=your_private_key_here
FUNDER_ADDRESS=your_wallet_address_here

# Persistence (Postgres & Redis required)
DATABASE_URL=postgresql+asyncpg://postgres:postgres_password@localhost:5432/polymatrix
REDIS_URL=redis://localhost:6379/0

# Risk Management
MAX_EXPOSURE_PER_MARKET=50.0
ALCHEMY_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your_alchemy_api_key_here

BASE_ORDER_SIZE=5.0
GRID_LEVELS=2
# 少而精：只在有 edge 时成交。BUY 挂在 fair_value - spread/2 及以下，不贴盘
QUOTE_BASE_SPREAD=0.02
QUOTE_PRICE_OFFSET_THRESHOLD=0.005

# --- 平衡「控制风险 + 多交易」时可改（仍保持每笔有 edge）---
# QUOTE_PRICE_OFFSET_THRESHOLD=0.003   # 跟价更紧，刷新更勤，更多成交机会
# GRID_LEVELS=3                         # 多一档买价，多一个价位被吃到
# QUOTE_BASE_SPREAD=0.015              # 可选：略紧 spread，略多成交、edge 略小
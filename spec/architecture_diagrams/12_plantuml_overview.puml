' PolyMatrix Engine - 系统整体架构图
' PlantUML 格式 - 可导出高清 PNG/SVG

@startuml PolyMatrix_Architecture

skinparam rectangle {
    BackgroundColor 16213E
    BorderColor 0F3460
    FontColor EAEaea
    RoundCorner 15
}

skinparam database {
    BackgroundColor 0F3460
    BorderColor E94560
    FontColor EAEaea
}

skinparam package {
    BackgroundColor 16213E
    BorderColor 0F3460
    FontColor EAEaea
}

title **PolyMatrix Engine V6.4 - 系统架构图**

package "客户端层" {
    [FastAPI 控制面] as API
    [Streamlit 驾驶舱] as Dashboard
}

package "数据面 (Data Plane)" {
    [Market WebSocket] as MarketWS
    [User WebSocket] as UserWS
    [REST Snapshot] as REST
    [Gamma API] as GammaAPI
    database "Redis" as Redis #pink
    queue "Redis PubSub" as TickQ #pink
    queue "Redis PubSub" as OBQ #pink
    queue "Redis PubSub" as CtrlQ #pink
    queue "Redis PubSub" as OrderStatusQ #pink
}

package "核心引擎层 (Core Engine)" {
    package "QuotingEngine × 2" {
        [AlphaModel] as Alpha
        [Grid Generator] as Grid
        [Diff Quoter] as DiffQuote
    }

    package "风控平面" {
        [Watchdog] as Watchdog
        [Kill Switch] as KillSwitch
        [Reconciler] as Reconcile
    }

    package "库存管理层" {
        [InventoryStateManager] as InvState #lightblue
    }

    package "自动路由" {
        [Portfolio Manager] as PortfolioMgr
        [评分引擎] as Scorer
        [MarketLifecycle] as Lifecycle
    }
}

package "执行平面 (Execution)" {
    [OMS Core] as OMS
    [CircuitBreaker] as CB
    [CLOB Client] as CLOB
    [Builder API] as Builder
}

package "数据层" {
    database "PostgreSQL" as PG
    database "Redis KV" as RedisKV
}

' 连接关系
API --> Dashboard
API --> Watchdog
API --> PortfolioMgr

MarketWS --> TickQ
MarketWS --> OBQ

TickQ --> Alpha
OBQ --> Alpha

GammaAPI --> PortfolioMgr
GammaAPI --> Alpha

Alpha --> Grid
Grid --> DiffQuote
DiffQuote --> OMS

Watchdog --> InvState
Watchdog --> KillSwitch
KillSwitch --> OMS
Reconcile --> PG

InvState --> OMS
InvState --> PG

PortfolioMgr --> Lifecycle
Lifecycle --> Alpha

OMS --> CLOB
OMS --> CB
CB --> CLOB
OMS --> Builder

CLOB --> MarketWS
CLOB --> UserWS

legend right
|= 组件类型 |= 颜色 |
| <back:#16213E> 客户端层 </back> | #0F3460 |
| <back:#16213E> 数据面 </back> | #0891B2 |
| <back:#16213E> 引擎层 </back> | #7C3AED |
| <back:#16213E> 风控层 </back> | #DC2626 |
| <back:#16213E> 执行层 </back> | #059669 |
| <back:#16213E> 数据层 </back> | #64748B |
endlegend

footer **PolyMatrix Engine | 准机构级自动化做市引擎**

@enduml

' PolyMatrix Engine - 多层风控体系
' PlantUML 格式

@startuml Risk_Control_Layers

skinparam rectangle {
    BackgroundColor 16213E
    BorderColor 0F3460
    FontColor EAEaea
    RoundCorner 10
}

skinparam note {
    BackgroundColor 1a1a2e
    BorderColor 0891B2
    FontColor EAEaea
}

title **PolyMatrix Engine - 多层风控体系**

package "第一层: 报价前预检" #2d4a22 {
    note "MAX_EXPOSURE_PER_MARKET = $50\nGLOBAL_MAX_BUDGET = $1000\nMTM 持仓 + pending BUY" as L1
}

package "第二层: Watchdog 硬熔断" #4a2222 {
    rectangle "每秒检查\nexposure > MAX?" as L2A
    rectangle "trigger_kill_switch()\n撤单 + suspend + Redis" as L2B
    L2A --> L2B
}

package "第三层: REST 周期对账" #224a4a {
    rectangle "60s 间隔\nreconciliation_loop()" as L3A
    rectangle "GET /positions\nPolymarket Data API" as L3B
    rectangle "差异 > tolerance?\n覆盖 InventoryLedger" as L3C
    L3A --> L3B --> L3C
}

package "第四层: 硬重置强制对账" #4a224a {
    rectangle "每 5 分钟\nhard_reset_cycle()" as L4A
    rectangle "CLOB cancel_all\n全钱包撤单" as L4B
    rectangle "reconcile(force=True)\n绕过时间保护" as L4C
    L4A --> L4B --> L4C
}

note "时间保护: 本地成交后 8s 内\n跳过对账覆盖" as TimeGuard
TimeGuard .. L3C

legend right
|= 层次 |= 检查频率 |= 触发动作 |
| L1 预检 | 每个 Tick | 跳过报价 |
| L2 Watchdog | 1s | 撤单 + suspend |
| L3 REST对账 | 60s | 覆盖 DB |
| L4 硬重置 | 5min | 强制对账 + 冻结 |
endlegend

footer **四层风控，全方位保障资金安全**

@enduml
